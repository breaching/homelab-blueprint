<!--
  Wazuh custom rules pour sshd MODERN format (Debian 13 / Ubuntu 24.04+).
  Append à /var/ossec/etc/rules/local_rules.xml du MANAGER.
  Reload via `systemctl restart wazuh-manager`.

  Why : default Wazuh rules 5710/5712 matchent l'ancien format
  ("Failed password for", "invalid user"). Modern sshd utilise
  "Connection closed by authenticating user X HOST PORT" → invisible
  pour les rules par défaut.

  ✅ STATUS validé via wazuh-logtest : ces rules MATCHENT pour le pattern
  "Connection closed by authenticating user X" (= valid system user qui rate
  l'auth, ex sshd test avec `nobody`). Pour les random invalid usernames
  (= brute force réaliste type "fresh-1, admin, root etc"), Wazuh built-in
  rule 5712 (level 10) catch déjà → Telegram fire automatiquement.

  Couverture combinée (default + custom) :
  - Random invalid usernames (8+ in 120s) → rule 5712 default → L10 → Tg ✅
  - Valid username repeated auth fail (5+ in 60s) → rule 100301 custom → L11 → Tg ✅
  - Connection drop penalty mode (sshd MaxAuthTries enforce) → rule 100302 custom → L10 → Tg ✅
-->
<group name="syslog,sshd,custom,">

  <!-- Modern sshd: failed auth attempt -->
  <!-- Chain off built-in 5722 ("Connection closed", silent level 0) → narrower
       match for "authenticating user" (= mid-auth disconnect = failed) -->
  <rule id="100300" level="5">
    <if_sid>5722</if_sid>
    <match>authenticating user</match>
    <description>sshd: failed authentication attempt (modern format, $(srcip))</description>
    <group>authentication_failed,</group>
  </rule>

  <!-- Frequency: 5+ failed auth in 60s = brute force -->
  <rule id="100301" level="11" frequency="5" timeframe="60">
    <if_matched_sid>100300</if_matched_sid>
    <description>sshd: brute force (5+ failed auth in 60s, modern sshd)</description>
    <group>attack,authentication_failures,</group>
  </rule>

  <!-- sshd "drop connection ... penalty: failed authentication" -->
  <rule id="100302" level="10">
    <if_sid>5700</if_sid>
    <match>drop connection</match>
    <regex>penalty: failed authentication</regex>
    <description>sshd: connection dropped (penalty mode = active brute force)</description>
    <group>attack,authentication_failures,</group>
  </rule>

  <!-- Modern sshd: "Disconnected from authenticating user" - chain off 5700 -->
  <rule id="100303" level="5">
    <if_sid>5700</if_sid>
    <match>Disconnected from authenticating user</match>
    <description>sshd: client disconnect mid-auth (likely failed)</description>
    <group>authentication_failed,</group>
  </rule>

  <!-- Aggregate: 100303 also feeds brute-force frequency -->
  <rule id="100304" level="11" frequency="8" timeframe="120">
    <if_matched_sid>100303</if_matched_sid>
    <description>sshd: brute force (8+ disconnects in 120s)</description>
    <group>attack,authentication_failures,</group>
  </rule>

</group>
